rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner() { return existing().userId == request.auth.uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'createdAt'])
        && data.keys().size() == 2
        && data.email is string && data.email.size() >= 3 && data.email.size() <= 255
        && data.createdAt == request.time;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId
        && incoming().diff(existing()).affectedKeys().hasOnly(['email'])
        && incoming().email is string && incoming().email.size() <= 255
        && incoming().createdAt == existing().createdAt;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['userId', 'name', 'description', 'material', 'price', 'weight', 'category', 'subCategory', 'seoTags', 'sustainabilityFilters', 'createdAt'])
        && data.keys().size() == 11
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 255
        && data.description is string && data.description.size() <= 2000
        && data.material is string && data.material.size() <= 255
        && data.price is number
        && data.weight is number
        && data.category is string && data.category.size() <= 255
        && data.subCategory is string && data.subCategory.size() <= 255
        && data.seoTags is list && data.seoTags.size() <= 50 && (data.seoTags.size() == 0 || data.seoTags[0] is string)
        && data.sustainabilityFilters is list && data.sustainabilityFilters.size() <= 50 && (data.sustainabilityFilters.size() == 0 || data.sustainabilityFilters[0] is string)
        && data.createdAt is timestamp;
    }

    match /products/{productId} {
      allow get: if isSignedIn() && isOwner();
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner() && isValidProduct(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner();
    }

    function isValidProposal(data) {
      return data.keys().hasAll(['userId', 'clientName', 'budget', 'recommendedProducts', 'totalCost', 'budgetRemaining', 'impactSummary', 'createdAt'])
        && data.keys().size() == 8
        && data.userId == request.auth.uid
        && data.clientName is string && data.clientName.size() <= 255
        && data.budget is number
        && data.recommendedProducts is list && data.recommendedProducts.size() <= 100 && (data.recommendedProducts.size() == 0 || data.recommendedProducts[0] is map)
        && data.totalCost is number
        && data.budgetRemaining is number
        && data.impactSummary is string && data.impactSummary.size() <= 5000
        && data.createdAt is timestamp;
    }

    match /proposals/{proposalId} {
      allow get: if isSignedIn() && isOwner();
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(proposalId) && isValidProposal(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && isOwner() && isValidProposal(incoming()) && incoming().createdAt == existing().createdAt && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner();
    }

    function isValidAILog(data) {
      return data.keys().hasAll(['userId', 'module', 'prompt', 'response', 'timestamp'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.module is string && data.module.size() <= 255
        && data.prompt is string && data.prompt.size() <= 5000
        && data.response is string && data.response.size() <= 10000
        && data.timestamp is timestamp;
    }

    match /aiLogs/{aiLogId} {
      allow get: if isSignedIn() && isOwner();
      allow list: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(aiLogId) && isValidAILog(incoming()) && incoming().timestamp == request.time;
      allow update: if false; // AI Logs shouldn't be edited
      allow delete: if isSignedIn() && isOwner();
    }
  }
}
