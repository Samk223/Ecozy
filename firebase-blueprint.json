{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["email", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A product created by a user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "material": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "weight": {
          "type": "number"
        },
        "category": {
          "type": "string"
        },
        "subCategory": {
          "type": "string"
        },
        "seoTags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sustainabilityFilters": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["userId", "name", "description", "material", "price", "weight", "category", "subCategory", "seoTags", "sustainabilityFilters", "createdAt"]
    },
    "Proposal": {
      "title": "Proposal",
      "description": "A generated proposal by a user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "clientName": {
          "type": "string"
        },
        "budget": {
          "type": "number"
        },
        "recommendedProducts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "product": { "type": "string" },
              "quantity": { "type": "number" },
              "cost": { "type": "number" }
            }
          }
        },
        "totalCost": {
          "type": "number"
        },
        "budgetRemaining": {
          "type": "number"
        },
        "impactSummary": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["userId", "clientName", "budget", "recommendedProducts", "totalCost", "budgetRemaining", "impactSummary", "createdAt"]
    },
    "AILog": {
      "title": "AILog",
      "description": "Log of AI interactions",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string"
        },
        "module": {
          "type": "string"
        },
        "prompt": {
          "type": "string"
        },
        "response": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": ["userId", "module", "prompt", "response", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Users"
    },
    "/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Products managed by users"
    },
    "/proposals/{proposalId}": {
      "schema": {
        "$ref": "#/entities/Proposal"
      },
      "description": "Proposals generated by users"
    },
    "/aiLogs/{aiLogId}": {
      "schema": {
        "$ref": "#/entities/AILog"
      },
      "description": "AI interaction logs"
    }
  }
}
